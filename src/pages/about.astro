---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="About | José Illán"
	description="About José Illán — background, interests, and approach to data, cloud, and AI work."
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="I enjoy turning messy processes into reliable systems, useful data products, and practical AI workflows."
			>
				<img width="1553" height="873" src="/assets/portrait.jpg" alt="José Illán" />
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I'm a data and cloud-focused engineer based in Zurich, with a strong interest in
						building systems that are both technically solid and genuinely useful for the people
						who rely on them.
					</p>
					<p>
						What motivates me most is working across the full path from raw data or vague ideas to
						clear outputs: pipelines, dashboards, automation, internal tools, and AI-powered
						products that make decisions faster and operations smoother.
					</p>
					<p>
						I'm especially interested in data engineering roles and in problems connected to
						analytics, finance, operations, and scalable product infrastructure.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">What I work on</h2>
				<div class="content">
					<p>
						Most of my interests sit at the intersection of data engineering, cloud architecture,
						and applied AI. I enjoy designing data flows, shaping analytics-ready models,
						orchestrating workflows, and creating systems that are easy to reason about in
						production.
					</p>
					<p>
						I also like projects where technical execution needs business context: forecasting,
						metrics, internal search, operational dashboards, or automation that saves time and
						reduces manual work.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">How I work</h2>
				<div class="content">
					<p>
						I value clear thinking, maintainable systems, and honest trade-offs. I prefer robust
						foundations over unnecessary complexity, and I care about documentation, naming,
						observability, and handoffs just as much as shipping code.
					</p>
					<p>
						My goal is simple: build things that work, make them understandable, and leave them in
						better shape than I found them.
					</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
